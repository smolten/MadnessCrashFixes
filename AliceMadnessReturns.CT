  if amrZkTimer then
    pcall(function() amrZkTimer.Enabled = false; amrZkTimer.destroy() end)
    amrZkTimer = nil
  end
  local process_alive = amrProcessAlive and amrProcessAlive()
  if process_alive then
    local ok, err = pcall(function()
      autoAssemble([[
AliceMadnessReturns.exe+37E82A:
  db 8D 85 10 FF FF FF

dealloc(amr_zk_cave)
dealloc(amr_zk_gnames)
dealloc(amr_zk_fired)
dealloc(amr_zk_last_obj)
dealloc(amr_zk_last_rb)
dealloc(amr_zk_last_oldflags)
dealloc(amr_zk_last_caller)
dealloc(amr_zk_kill_count)
      ]])
    end)
    if not ok then
      local msg = "[zombie-kill] Byte-restore failed: " .. tostring(err)
      if amrOut then amrOut(msg) else print(msg) end
    end
  else
    local msg = os.date("%H:%M:%S ") .. "[zombie-kill] Process gone — skipping byte restore"
    if amrOut then amrOut(msg) else print(msg) end
  end
  local syms = {
    "amr_zk_cave", "amr_zk_gnames", "amr_zk_fired", "amr_zk_last_obj",
    "amr_zk_last_rb", "amr_zk_last_oldflags", "amr_zk_last_caller",
    "amr_zk_kill_count",
  }
  for _, s in ipairs(syms) do
    if getAddress(s) ~= nil then unregisterSymbol(s) end
  end
end
