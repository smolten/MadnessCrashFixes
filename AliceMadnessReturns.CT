</AssemblerScript>
    </CheatEntry>
    <CheatEntry>
      <ID>7</ID>
      <Description>"Kill Zombie Breakable Object (Fix World 5 Rolling Ball Load 3 Crash)"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Kill Zombie Breakable Object — Fix Rolling Ball Load 3 Crash
  Chapter 5 World 3 rolling ball puzzle: transitioning through the
  door from puzzle 2 to puzzle 3 loads Chapter5_W3_HH2_03. During
  the load, a GameBreakableActor's collision component gets added to
  the physics tick iteration list BEFORE InitComponentRBPhys runs.
  The object has RF_PendingKill | RF_AsyncLoading — a zombie that
  will never initialize and never be removed. Setting MadnessPatch
  DisableBackgroundLevelStreaming to 0 (use Vanilla Async loading)
  also seems to fix this bug.

  Vanilla behavior: UE3 appError() formats
    "%s collisioncomponent %s not initialized deleteme %d"
  then calls RaiseException(1) → _exit(). Instant process death.

  Fix: hook the not-initialized branch at +0x37E82A. On first hit
  for any object, set bDeleteMe (bit 7 of ObjectFlags at [obj+0x3C])
  so the function's own early bDeleteMe check at +0x37E4E8 catches
  it on subsequent ticks. Log full details via amrOut (file append,
  no focus steal). Return cleanly via the function epilogue.

  Requires: entry ID 0 ("Fix Crashes") active for amrOut + amrProcessAlive.
}

[ENABLE]

{$lua}
if not amrProcessAlive or not amrProcessAlive() then
  error("[zombie-kill] AMR not attached — activate entry ID 0 first")
end
if not amrOut then
  error("[zombie-kill] amrOut not defined — activate entry ID 0 first")
end

-- Auto-heal: if our patch is already in place (stale from prior activation),
-- restore vanilla bytes so the AA assert below succeeds.
do
  local base = getAddress("AliceMadnessReturns.exe")
  local addr = base + 0x37E82A
  local vanilla = {0x8D, 0x85, 0x10, 0xFF, 0xFF, 0xFF}
  local first = readByte(addr)
  if first == 0xE9 then
    -- Stale patch detected — restore vanilla
    for i = 1, #vanilla do writeByte(addr + i - 1, vanilla[i]) end
    amrOut("[zombie-kill] Auto-healed stale patch at +37E82A")
  elseif first ~= vanilla[1] then
    local got = ""
    for i = 0, 5 do got = got .. string.format("%02X ", readByte(addr + i)) end
    error(string.format("[zombie-kill] Unexpected bytes at +37E82A: [%s], expected vanilla [8D 85 10 FF FF FF]", got))
  end
end
{$asm}

// GNames.Data address for FName resolution in the Lua logger
alloc(amr_zk_gnames, 4)
registersymbol(amr_zk_gnames)
amr_zk_gnames:
  dd 014723A4

// Flag: set to 1 by the cave when it kills a zombie. Lua polls this.
alloc(amr_zk_fired, 4)
registersymbol(amr_zk_fired)
amr_zk_fired:
  dd 0

// Last-killed object address (for Lua to read details)
alloc(amr_zk_last_obj, 4)
registersymbol(amr_zk_last_obj)
amr_zk_last_obj:
  dd 0

// Last-killed RB component address
alloc(amr_zk_last_rb, 4)
registersymbol(amr_zk_last_rb)
amr_zk_last_rb:
  dd 0

// Old flags before we set bDeleteMe
alloc(amr_zk_last_oldflags, 4)
registersymbol(amr_zk_last_oldflags)
amr_zk_last_oldflags:
  dd 0

// Caller return address (for callstack context)
alloc(amr_zk_last_caller, 4)
registersymbol(amr_zk_last_caller)
amr_zk_last_caller:
  dd 0

// Kill count (how many unique objects we've set bDeleteMe on)
alloc(amr_zk_kill_count, 4)
registersymbol(amr_zk_kill_count)
amr_zk_kill_count:
  dd 0

alloc(amr_zk_cave, 0x80, AliceMadnessReturns.exe+37E82A)
label(amr_zk_already_dead)

amr_zk_cave:
  // ESI = owning object, ECX = RB component (from `test byte [ecx+50],01`)
  // Check if bDeleteMe is already set (bit 7 of [esi+3C])
  test byte ptr [esi+3C], 80
  jnz amr_zk_already_dead

  // === First encounter: kill the zombie ===
  // Save old flags, object, RB, caller for Lua to read
  push eax
  mov eax, [esi+3C]
  mov [amr_zk_last_oldflags], eax
  // Set bDeleteMe: OR bit 7 into flags
  or eax, 00000080
  mov [esi+3C], eax
  pop eax
  mov [amr_zk_last_obj], esi
  mov [amr_zk_last_rb], ecx
  // Capture caller EIP from stack. Our cave was reached via:
  //   original site JMP -> cave. The return address of the FUNCTION
  //   is at [ebp+04] (standard frame pointer).
  push eax
  mov eax, [ebp+04]
  mov [amr_zk_last_caller], eax
  pop eax
  inc dword ptr [amr_zk_kill_count]
  // Signal Lua
  mov dword ptr [amr_zk_fired], 1

amr_zk_already_dead:
  // Clean return via function epilogue (stdcall, ret 0x14)
  xor eax, eax
  jmp AliceMadnessReturns.exe+38032F

assert(AliceMadnessReturns.exe+37E82A, 8D 85 10 FF FF FF)
AliceMadnessReturns.exe+37E82A:
  jmp amr_zk_cave
  nop


// === Lua poller: watch for kills and log full details ===
{$lua}
do
  -- GNames resolver (found this session: GNames.Data at [0x014723A4])
  local base = getAddress("AliceMadnessReturns.exe")
  local gnames_global = base + 0x10723A4  -- RVA of GNames.Data pointer

  local function resolveFName(idx)
    if not idx or idx == 0 then return "None" end
    local gnames_data = readInteger(gnames_global)
    if not gnames_data or gnames_data == 0 then return string.format("FName#%d", idx) end
    local entry = readInteger(gnames_data + idx * 4)
    if not entry or entry == 0 then return string.format("FName#%d", idx) end
    return readString(entry + 0x10, 64) or string.format("FName#%d", idx)
  end

  if amrZkTimer then
    pcall(function() amrZkTimer.Enabled = false; amrZkTimer.destroy() end)
    amrZkTimer = nil
  end
  amrZkTimer = createTimer(getMainForm(), false)
  amrZkTimer.Interval = 500
  amrZkTimer.OnTimer = function(t)
    if not amrProcessAlive() then
      t.Enabled = false
      return
    end
    local firedSym = getAddress("amr_zk_fired")
    if not firedSym or firedSym == 0 then return end
    local fired = readInteger(firedSym) or 0
    if fired == 0 then return end
    writeInteger(firedSym, 0)  -- acknowledge

    local objSym   = getAddress("amr_zk_last_obj")
    local rbSym    = getAddress("amr_zk_last_rb")
    local flagsSym = getAddress("amr_zk_last_oldflags")
    local callerSym = getAddress("amr_zk_last_caller")
    local countSym  = getAddress("amr_zk_kill_count")

    local obj       = readInteger(objSym) or 0
    local rb        = readInteger(rbSym) or 0
    local oldFlags  = readInteger(flagsSym) or 0
    local caller    = readInteger(callerSym) or 0
    local killCount = readInteger(countSym) or 0
    local base      = getAddress("AliceMadnessReturns.exe")

    -- Read object details
    local obj_vt     = readInteger(obj) or 0
    local obj_fname  = readInteger(obj + 0x2C) or 0
    local obj_outer  = readInteger(obj + 0x34) or 0
    local outer_fname = 0
    if obj_outer ~= 0 then outer_fname = readInteger(obj_outer + 0x2C) or 0 end

    -- Read RB component details
    local rb_vt   = readInteger(rb) or 0
    local rb_init = readBytes(rb + 0x50, 1) or 0

    -- Read caller stack (8 dwords from [ebp+04] area, but we only saved EIP.
    -- Also grab a few words from the object for context)
    local obj_10 = readInteger(obj + 0x10) or 0
    local obj_14 = readInteger(obj + 0x14) or 0

    local newFlags = readInteger(obj + 0x3C) or 0
    local timestamp = os.date("%H:%M:%S")

    amrOut("======================================================================")
    amrOut("====== ZOMBIE BREAKABLE OBJECT KILLED ================================")
    amrOut("======================================================================")
    amrOut(string.format("  Time:        %s  (kill #%d)", timestamp, killCount))
    amrOut(string.format("  Action:      Set bDeleteMe (bit 7) on uninitialized collision component owner"))
    amrOut(string.format("  Object:      %08X  class=%s  vtable=+%06X",
      obj, resolveFName(obj_fname), obj_vt - base))
    amrOut(string.format("  Outer:       %08X  name=%s",
      obj_outer, resolveFName(outer_fname)))
    amrOut(string.format("  RB Comp:     %08X  vtable=+%06X  init_byte=%02X",
      rb, rb_vt - base, rb_init))
    amrOut(string.format("  Flags:       %08X -> %08X  (bDeleteMe: 0 -> 1)", oldFlags, newFlags))
    amrOut(string.format("  PendingKill: %d  AsyncLoading: %d",
      math.floor(oldFlags / 0x2000000) % 2,
      math.floor(oldFlags / 0x8000000) % 2))
    amrOut(string.format("  Caller EIP:  %08X (+%06X)", caller, caller - base))
    amrOut(string.format("  [obj+10]:    %08X  [obj+14]: %08X", obj_10, obj_14))
    amrOut("======================================================================")
  end
  amrZkTimer.Enabled = true
  amrOut("[zombie-kill] Armed — watching for uninitialized collision components")
end
{$asm}


